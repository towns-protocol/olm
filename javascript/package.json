{
  "name": "@towns-protocol/olm",
  "type": "module",
  "version": "3.2.16",
  "description": "An implementation of the Double Ratchet cryptographic ratchet",
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "require": {
        "types": "./index.d.ts",
        "node": "./olm.node.cjs",
        "default": "./olm.web.cjs"
      },
      "import": {
        "types": "./index.d.ts",
        "node": "./olm.node.mjs",
        "default": "./olm.web.mjs"
      }
    }
  },
  "files": [
    "olm.web.mjs",
    "olm.node.mjs",
    "olm.web.cjs",
    "olm.node.cjs",
    "olm.wasm",
    "index.d.ts",
    "README.md"
  ],
  "scripts": {
    "build": "nix build .#javascript",
    "build:bundle": "tsup",
    "test": "vitest run"
  },
  "repository": {
    "type": "git",
    "url": "git+https://gitlab.matrix.org/matrix-org/olm.git"
  },
  "keywords": [
    "matrix-org"
  ],
  "author": "matrix.org",
  "license": "Apache-2.0",
  "bugs": {
    "url": "https://github.com/matrix-org/olm/issues"
  },
  "homepage": "https://gitlab.matrix.org/matrix-org/olm",
  "devDependencies": {
    "tsup": "^8.4.0",
    "typescript": "^5.8.3",
    "vitest": "^3.1.2"
  }
}
