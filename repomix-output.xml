        }
        subcase("size should grow to 3") {
            cout << "+ 1" << endl;
            data.push_back(666);
            cout << "== size: " << data.size() << endl;
        }
    }
    subcase("size should grow to 1") {
        cout << "+ 1" << endl;
        data.push_back(42);
        cout << "== size: " << data.size() << endl;
    }
}

int main() {
    passed_subcases.clear();
    do {
        has_skipped = false;
        current_level = 0;
        entered_levels.clear();
        test();
    } while(has_skipped == true);

    return 0;
}
