<file path=".circleci/config.yml">
version: 2
jobs:
  build:
    docker:
      - image: trzeci/emscripten
      
    working_directory: ~/repo

    steps:
      - checkout
      - run:
          name: Native Compile
          command: make
      - run:
          name: Native Tests
          command: make test
      - run:
          name: JS Compile
          command: make js
      - run:
          name: Install JS Deps
          working_directory: ~/repo/javascript
          command: npm install
      - run:
          name: JS Tests
          working_directory: ~/repo/javascript
          command: npm run test
</file>

<file path="cmake/OlmConfig.cmake.in">
get_filename_component(Olm_CMAKE_DIR "${CMAKE_CURRENT_LIST_FILE}" PATH)
include(CMakeFindDependencyMacro)

list(APPEND CMAKE_MODULE_PATH ${Olm_CMAKE_DIR})
list(REMOVE_AT CMAKE_MODULE_PATH -1)

if(NOT TARGET Olm::olm)
  include("${Olm_CMAKE_DIR}/OlmTargets.cmake")
endif()

set(Olm_LIBRARIES Olm::olm)
</file>

